# Anthropic API key for news summarization
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — acepta ambos formatos de nombre:
# Formato Vercel KV:
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
# Formato Upstash directo (alternativo):
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Secret for cron job authentication
CRON_SECRET=your-random-secret-here

# Base URL for OG images and metadata
NEXT_PUBLIC_BASE_URL=https://votainformadoco.org

# Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=https://...@o...ingest.sentry.io/...
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=voto-informado
SENTRY_AUTH_TOKEN=sntrys_...
